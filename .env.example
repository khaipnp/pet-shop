# ─── Pet Shop - Environment Variables ────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database (PostgreSQL) ──────────────────────────────
# Local dev: use your local PostgreSQL
DATABASE_URL=postgresql://petshop:petshop_pass@localhost:5432/pet_shop

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-key
JWT_EXPIRES_IN=7d

# ─── SePay (optional - for bank transfer payments) ──────
# SEPAY_WEBHOOK_SECRET=
